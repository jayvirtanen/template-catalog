pipeline {
    agent{
      kubernetes{
      inheritFrom "${maven_template}"
      defaultContainer 'maven'
      }
    }
    stages {
        stage('Checkout') {
            steps {
                git branch: "${github_branch}", credentialsId: "${github_creds}", url: "${github_repo}"
            }
        }
        stage('Build') {
            steps {
                sh 'mvn -B -DskipTests clean package'
            }
        }
    }
}
